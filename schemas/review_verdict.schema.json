{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approved", "revision_needed", "rejected"]
    },
    "overall_assessment": { "type": "string" },
    "quality_scores": {
      "type": "object",
      "properties": {
        "correctness": { "type": "integer", "minimum": 1, "maximum": 10 },
        "code_quality": { "type": "integer", "minimum": 1, "maximum": 10 },
        "test_coverage": { "type": "integer", "minimum": 1, "maximum": 10 },
        "spec_adherence": { "type": "integer", "minimum": 1, "maximum": 10 }
      },
      "required": ["correctness", "code_quality", "test_coverage", "spec_adherence"]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "nit"]
          },
          "category": {
            "type": "string",
            "enum": ["bug", "security", "performance", "style", "logic", "test_gap", "spec_deviation"]
          },
          "file_path": { "type": ["string", "null"] },
          "line_range": { "type": ["string", "null"] },
          "description": { "type": "string" },
          "suggested_fix": { "type": ["string", "null"] }
        },
        "required": ["severity", "category", "description"]
      }
    },
    "strengths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "feedback": {
      "type": ["object", "null"],
      "properties": {
        "critical_issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "severity": {
                "type": "string",
                "enum": ["critical", "major", "minor", "nit"]
              },
              "category": {
                "type": "string",
                "enum": ["bug", "security", "performance", "style", "logic", "test_gap", "spec_deviation"]
              },
              "file_path": { "type": ["string", "null"] },
              "line_range": { "type": ["string", "null"] },
              "description": { "type": "string" },
              "suggested_fix": { "type": ["string", "null"] }
            },
            "required": ["severity", "category", "description"]
          }
        },
        "guidance": { "type": "string" },
        "keep_unchanged": {
          "type": "array",
          "items": { "type": "string" }
        },
        "revision_round": { "type": "integer" }
      },
      "required": ["critical_issues", "guidance", "keep_unchanged", "revision_round"]
    }
  },
  "required": [
    "verdict",
    "overall_assessment",
    "quality_scores",
    "issues",
    "strengths"
  ]
}
