{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "overall_red_assessment": { "type": "string" },
    "challenges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "nit"]
          },
          "category": {
            "type": "string",
            "enum": ["bug", "security", "performance", "style", "logic", "test_gap", "spec_deviation"]
          },
          "claim": { "type": "string" },
          "confidence": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "evidence": { "type": ["string", "null"] },
          "suggested_check": { "type": ["string", "null"] }
        },
        "required": ["id", "severity", "category", "claim", "confidence"]
      }
    }
  },
  "required": ["overall_red_assessment", "challenges"]
}
